function styleDynamicHeaders_(sheet) {
  const h = getHeaderMap_(sheet);
  const maxRows = Math.max(sheet.getMaxRows() - HEADER_ROW, 1);

  const textColumns = [
    "Shareholder Name",
    "Shareholder Type",
    "UBO Name",
    "UBO Type",
  ];

  const integerColumns = [
    "Shareholder Age",
    "UBO Age",
  ];

  const decimalColumns = [
    "Shareholder Contribution",
    "Shareholder Ownership %",
    "UBO %",
    "UBO Max %",
  ];

  OV_DYNAMIC_HEADERS.forEach(header => {
    const col = findCol_(h, [header], false);

    if (!col) return;

    sheet
      .getRange(HEADER_ROW, col)
      .setFontWeight("bold")
      .setBackground("#1c5c5c")
      .setFontColor("#ffffff");

    const bodyRange = sheet.getRange(HEADER_ROW + 1, col, maxRows, 1);

    bodyRange.clearFormat();

    if (textColumns.indexOf(header) !== -1) {
      bodyRange.setNumberFormat("@");
    }

    if (integerColumns.indexOf(header) !== -1) {
      bodyRange.setNumberFormat("0");
    }

    if (decimalColumns.indexOf(header) !== -1) {
      bodyRange.setNumberFormat("#,##0.##");
    }
  });
}

