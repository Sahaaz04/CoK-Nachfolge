function setupCockpit() {
  normalizeSheetNames_();

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const overview = getSheet_(ss, SHEETS.overview);
  const shareholders = getSheet_(ss, SHEETS.shareholders);
  const ubos = getSheet_(ss, SHEETS.ubos);
  const cockpit = getOrCreateSheet_(ss, SHEETS.cockpit);

  const previousCompanyId = cleanId_(
    cockpit.getRange(COCKPIT_COMPANY_CELL).getDisplayValue()
  );

  setupCockpitLayout_(cockpit);

  const ovH = getHeaderMap_(overview);
  const shH = getHeaderMap_(shareholders);
  const uboH = getHeaderMap_(ubos);

  const ovCompanyCol = findCol_(ovH, ALIASES.companyId, true);
  const companyIds = getColumnValues_(overview, ovCompanyCol);

  const companyCell = cockpit.getRange(COCKPIT_COMPANY_CELL);

  setDropdownAndSafeValue_(companyCell, companyIds, previousCompanyId);

  const selectedCompanyId = cleanId_(companyCell.getDisplayValue());

  const shMap = buildDropdownMap_(
    shareholders,
    findCol_(shH, ALIASES.companyId, true),
    findCol_(shH, ALIASES.shareholderName, true)
  );

  const uboMap = buildDropdownMap_(
    ubos,
    findCol_(uboH, ALIASES.companyId, true),
    findCol_(uboH, ALIASES.uboName, true)
  );

  setDropdownAndSafeValue_(
    cockpit.getRange(CK.shareholderName, 2),
    shMap[selectedCompanyId] || []
  );

  setDropdownAndSafeValue_(
    cockpit.getRange(CK.uboName, 2),
    uboMap[selectedCompanyId] || []
  );

  setCockpitFormulas_(cockpit, ovH, shH, uboH);
}

function setupCockpitLayout_(sheet) {
  if (sheet.getMaxRows() < 45) {
    sheet.insertRowsAfter(sheet.getMaxRows(), 45 - sheet.getMaxRows());
  }

  if (sheet.getMaxColumns() < 4) {
    sheet.insertColumnsAfter(sheet.getMaxColumns(), 4 - sheet.getMaxColumns());
  }

  const fullRange = sheet.getRange(
    1,
    1,
    sheet.getMaxRows(),
    sheet.getMaxColumns()
  );

  try {
    fullRange.breakApart();
  } catch (e) {}

  fullRange.clearContent();
  fullRange.clearFormat();
  fullRange.clearDataValidations();

  sheet
    .getRange("A1:B1")
    .merge()
    .setValue("OpenRegister Succession Cockpit")
    .setFontWeight("bold")
    .setFontSize(14)
    .setBackground("#1c5c5c")
    .setFontColor("#ffffff");

  label_(sheet, CK.companyId, "Company ID");

  section_(sheet, 4, "Company");
  label_(sheet, CK.companyName, "Company Name");
  label_(sheet, CK.legalForm, "Legal Form");
  label_(sheet, CK.foundingYear, "Founding Year");
  label_(sheet, CK.city, "City");
  label_(sheet, CK.website, "Website");
  label_(sheet, CK.openregisterWz, "OpenRegister WZ Code");
  label_(sheet, CK.northdataWz, "NorthData WZ Code");
  label_(sheet, CK.openregisterRevenue, "OpenRegister Revenue €");
  label_(sheet, CK.northdataRevenue, "NorthData Revenue €");
  label_(sheet, CK.employees, "Employees");

  section_(sheet, 16, "Shareholder Drilldown");
  label_(sheet, CK.shareholderName, "Shareholder Name");
  label_(sheet, CK.shareholderAge, "Shareholder Age");
  label_(sheet, CK.shareholderType, "Shareholder Type");
