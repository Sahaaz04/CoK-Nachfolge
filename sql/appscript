function setLookupFormula_(
  overview,
  row,
  ovH,
  outputHeader,
  sourceSheet,
  sourceH,
  companyAliases,
  nameAliases,
  outputAliases,
  companyCellA1,
  selectedNameA1
) {
  const outputCol = findCol_(ovH, [outputHeader], true);
  const sourceCompanyL = colToLetter_(findCol_(sourceH, companyAliases, true));
  const sourceNameL = colToLetter_(findCol_(sourceH, nameAliases, true));
  const sourceOutputCol = findCol_(sourceH, outputAliases, false);

  if (!sourceOutputCol) {
    overview.getRange(row, outputCol).clearContent();
    return;
  }

  const sourceOutputL = colToLetter_(sourceOutputCol);
  const key = `UPPER(TRIM(${companyCellA1}))&"|"&TRIM(${selectedNameA1})`;
  const array = `ARRAYFORMULA(UPPER(TRIM('${sourceSheet}'!${sourceCompanyL}:${sourceCompanyL}))&"|"&TRIM('${sourceSheet}'!${sourceNameL}:${sourceNameL}))`;

  overview
    .getRange(row, outputCol)
    .setFormula(
      `=IF(${selectedNameA1}="","",IFERROR(INDEX('${sourceSheet}'!${sourceOutputL}:${sourceOutputL},MATCH(${key},${array},0)),""))`
    );
}

/****************************************************
UTILITY FUNCTIONS
****************************************************/

function normalizeSheetNames_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const oldSheet = ss.getSheetByName(SHEETS.oldOwners);
  const newSheet = ss.getSheetByName(SHEETS.shareholders);

  if (oldSheet && !newSheet) {
    oldSheet.setName(SHEETS.shareholders);
    return;
  }

  if (oldSheet && newSheet) {
    ss.deleteSheet(oldSheet);
  }
}

function getSheet_(ss, name) {
  const sheet = ss.getSheetByName(name);

  if (!sheet) {
    throw new Error("Missing required sheet: " + name);
  }

  return sheet;
}

function getOrCreateSheet_(ss, name) {
  return ss.getSheetByName(name) || ss.insertSheet(name);
}

function getHeaderMap_(sheet) {
  const lastCol = Math.max(sheet.getLastColumn(), 1);

  const headers = sheet
    .getRange(HEADER_ROW, 1, 1, lastCol)
    .getDisplayValues()[0];

  const map = {};

  headers.forEach((h, i) => {
    const key = norm_(h);

    if (key && !map[key]) {
      map[key] = i + 1;
    }
  });

  return map;
}

function findCol_(headerMap, aliases, required) {
  for (let i = 0; i < aliases.length; i++) {
    const key = norm_(aliases[i]);

    if (headerMap[key]) {
      return headerMap[key];
    }
  }

  if (required) {
    throw new Error("Missing required header: " + aliases.join(" / "));
  }

  return null;
}

function buildDropdownMap_(sheet, companyCol, nameCol) {
  const values = sheet.getDataRange().getDisplayValues();
  const map = {};

  for (let i = HEADER_ROW; i < values.length; i++) {
    const companyId = cleanId_(values[i][companyCol - 1]);
    const name = cleanText_(values[i][nameCol - 1]);

    if (!companyId || !name) continue;

    if (!map[companyId]) {
      map[companyId] = [];
    }

    if (map[companyId].indexOf(name) === -1) {
      map[companyId].push(name);
    }
  }

  return map;
}

function getColumnValues_(sheet, col) {
  const lastRow = sheet.getLastRow();

  if (lastRow <= HEADER_ROW) {
    return [];
  }

  return dedupe_(
    sheet
      .getRange(HEADER_ROW + 1, col, lastRow - HEADER_ROW, 1)
      .getDisplayValues()
      .flat()
      .map(cleanId_)
      .filter(Boolean)
  );
}

function buildListValidation_(values) {
  const options = dedupe_((values || []).map(cleanText_).filter(Boolean));

  if (options.length === 0) {
    return null;
  }

  return SpreadsheetApp.newDataValidation()
    .requireValueInList(options, true)
    .setAllowInvalid(true)
    .build();
}

function setDropdownAndSafeValue_(cell, values, preferredValue) {
  const options = dedupe_((values || []).map(cleanText_).filter(Boolean));

  if (options.length === 0) {
    cell.clearDataValidations();
    cell.clearContent();
    return;
  }

  const rule = SpreadsheetApp.newDataValidation()
    .requireValueInList(options, true)
    .setAllowInvalid(true)
    .build();

  cell.setDataValidation(rule);

  const preferred = cleanText_(preferredValue || cell.getDisplayValue());

  if (options.indexOf(preferred) !== -1) {
    cell.setValue(preferred);
  } else {
    cell.setValue(options[0]);
  }
}

function label_(sheet, row, text) {
  sheet
    .getRange(row, 1)
    .setValue(text)
    .setFontWeight("bold")
    .setBackground("#EAF3F3");
}

function section_(sheet, row, text) {
  sheet
    .getRange(row, 1, 1, 2)
    .merge()
    .setValue(text)
    .setFontWeight("bold")
    .setBackground("#1c5c5c")
    .setFontColor("#ffffff");
}

function colToLetter_(column) {
  let temp = "";
  let letter = "";

  while (column > 0) {
    temp = (column - 1) % 26;
    letter = String.fromCharCode(temp + 65) + letter;
    column = (column - temp - 1) / 26;
  }

  return letter;
}

function dedupe_(list) {
  const seen = new Set();
  const out = [];

  list.forEach(x => {
    const cleaned = cleanText_(x);

    if (!cleaned || seen.has(cleaned)) return;

    seen.add(cleaned);
    out.push(cleaned);
  });

  return out;
}

function norm_(value) {
  return cleanText_(value)
    .toLowerCase()
    .replace(/[€]/g, "eur")
    .replace(/[^a-z0-9]+/g, "_")
    .replace(/^_+|_+$/g, "");
}

function cleanId_(value) {
  return String(value || "")
    .replace(/\n/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .toUpperCase();
}

function cleanText_(value) {
  return String(value || "")
    .replace(/\n/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}
