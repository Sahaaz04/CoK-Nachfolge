      bodyRange.setNumberFormat("@");
    }

    if (integerColumns.indexOf(header) !== -1) {
      bodyRange.setNumberFormat("0");
    }

    if (decimalColumns.indexOf(header) !== -1) {
      bodyRange.setNumberFormat("#,##0.##");
    }
  });
}

function applyOverviewColumnFormats_(sheet) {
  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();

  if (lastRow <= HEADER_ROW || lastCol < 1) return;

  const headers = sheet
    .getRange(HEADER_ROW, 1, 1, lastCol)
    .getDisplayValues()[0];

  const bodyRows = Math.max(lastRow - HEADER_ROW, 1);

  const integerHeaders = new Set([
    "Founding Year",
