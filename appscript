    "Fit Score",
  ]);

  const moneyHeaders = new Set([
    "Northdata Revenue €",
    "OpenRegister Revenue €",
    "Northdata Balance Sheet Total €",
    "Openregister Balance Sheet Total €",
    "Northdata Net Income €",
    "Openregister Net Income €",
    "Northdata Equity €",
    "Openregister Equity €",
    "Northdata Cash €",
    "Openregister Cash €",
    "Northdata Liabilities €",
    "Openregister Liabilities €",
    "Real Estate €",
    "Capital Amount €",
    "Shareholder Contribution",
  ]);

  const percentHeaders = new Set([
    "Shareholder Ownership %",
    "UBO %",
    "UBO Max %",
    "Largest Owner %",
    "Main Owner %",
    "Main UBO %",
    "Main UBO Max %",
  ]);

  const dateHeaders = new Set([
    "Northdata Financials Date",
    "Openregister Financials Date",
  ]);

  const booleanHeaders = new Set([
    "Active",
    "Has Sole Owner",
    "Owner Managed",
    "Family Owned",
    "Has Majority Owner",
  ]);

  for (let col = 1; col <= lastCol; col++) {
    const header = cleanText_(headers[col - 1]);
    const range = sheet.getRange(HEADER_ROW + 1, col, bodyRows, 1);

    range.clearFormat();

    if (moneyHeaders.has(header)) {
      range.setNumberFormat("#,##0.00");
    } else if (integerHeaders.has(header)) {
      range.setNumberFormat("0");
    } else if (percentHeaders.has(header)) {
      range.setNumberFormat("0.00");
