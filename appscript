function setCockpitXlookup_(cockpit, row, sourceSheet, sourceIdL, sourceH, outputAliases) {
  const outputCol = findCol_(sourceH, outputAliases, false);

  if (!outputCol) {
    cockpit.getRange(row, 2).clearContent();
    return;
  }

  const outputL = colToLetter_(outputCol);

  cockpit
    .getRange(row, 2)
    .setFormula(
      `=IFERROR(XLOOKUP($B$3,'${sourceSheet}'!${sourceIdL}:${sourceIdL},'${sourceSheet}'!${outputL}:${outputL}),"")`
    );
}

function setCockpitCompositeLookup_(
  cockpit,
  row,
  sourceSheet,
  sourceH,
  companyAliases,
  nameAliases,
  outputAliases,
  selectedNameA1
) {
  const sourceCompanyL = colToLetter_(findCol_(sourceH, companyAliases, true));
  const sourceNameL = colToLetter_(findCol_(sourceH, nameAliases, true));
  const sourceOutputCol = findCol_(sourceH, outputAliases, false);

  if (!sourceOutputCol) {
    cockpit.getRange(row, 2).clearContent();
    return;
  }

  const sourceOutputL = colToLetter_(sourceOutputCol);
  const key = `UPPER(TRIM($B$3))&"|"&TRIM(${selectedNameA1})`;
  const array = `ARRAYFORMULA(UPPER(TRIM('${sourceSheet}'!${sourceCompanyL}:${sourceCompanyL}))&"|"&TRIM('${sourceSheet}'!${sourceNameL}:${sourceNameL}))`;

  cockpit
    .getRange(row, 2)
    .setFormula(
      `=IFERROR(INDEX('${sourceSheet}'!${sourceOutputL}:${sourceOutputL},MATCH(${key},${array},0)),"")`
    );
}

