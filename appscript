function setupOverviewDropdowns() {
  normalizeSheetNames_();

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const overview = getSheet_(ss, SHEETS.overview);
  const shareholders = getSheet_(ss, SHEETS.shareholders);
  const ubos = getSheet_(ss, SHEETS.ubos);

  overview
    .getRange(1, 1, overview.getMaxRows(), overview.getMaxColumns())
    .clearDataValidations();

  deleteDynamicColumns_(overview);
  deleteColumnsByHeader_(overview, [DIVISION_HEADER, "Division"]);
  deleteColumnsByHeader_(overview, REMOVED_OVERVIEW_HEADERS);

  reorderOverviewColumns_(overview);
  syncDivisionsColumn_(overview);
  resetDynamicColumnsAfterFinancialDate_(overview);

  const ovH = getHeaderMap_(overview);
  const shH = getHeaderMap_(shareholders);
  const uboH = getHeaderMap_(ubos);

  const ovCompanyCol = findCol_(ovH, ALIASES.companyId, true);

  const shMap = buildDropdownMap_(
    shareholders,
    findCol_(shH, ALIASES.companyId, true),
    findCol_(shH, ALIASES.shareholderName, true)
  );

  const uboMap = buildDropdownMap_(
    ubos,
    findCol_(uboH, ALIASES.companyId, true),
    findCol_(uboH, ALIASES.uboName, true)
  );

  const shNameCol = findCol_(ovH, ["Shareholder Name"], true);
  const uboNameCol = findCol_(ovH, ["UBO Name"], true);

  const lastRow = overview.getLastRow();

  if (lastRow <= HEADER_ROW) return;

  const totalRows = lastRow - HEADER_ROW;

  const overviewData = overview
    .getRange(HEADER_ROW + 1, 1, totalRows, overview.getLastColumn())
    .getDisplayValues();

  const shRules = [];
  const uboRules = [];
  const shDefaults = [];
  const uboDefaults = [];

  for (let i = 0; i < totalRows; i++) {
    const rowNum = HEADER_ROW + 1 + i;
    const companyId = cleanId_(overviewData[i][ovCompanyCol - 1]);

    const shOptions = shMap[companyId] || [];
    const uboOptions = uboMap[companyId] || [];

    shRules.push([buildListValidation_(shOptions)]);
    uboRules.push([buildListValidation_(uboOptions)]);

    shDefaults.push([shOptions.length ? shOptions[0] : ""]);
    uboDefaults.push([uboOptions.length ? uboOptions[0] : ""]);

    setOverviewFormulas_(overview, rowNum, ovH, shH, uboH);
  }

  const shRange = overview.getRange(HEADER_ROW + 1, shNameCol, totalRows, 1);
  const uboRange = overview.getRange(HEADER_ROW + 1, uboNameCol, totalRows, 1);

  shRange.setValues(shDefaults);
  uboRange.setValues(uboDefaults);

  shRange.setDataValidations(shRules);
  uboRange.setDataValidations(uboRules);

  styleDynamicHeaders_(overview);
  styleOverviewHeader_(overview);
  applyOverviewColumnFormats_(overview);
}

function reorderOverviewColumns_(sheet) {
  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();

  if (lastRow < HEADER_ROW || lastCol < 1) return;

  const valueRange = sheet.getRange(1, 1, lastRow, lastCol);
  const values = valueRange.getValues();
  const formulas = valueRange.getFormulas();

  const headers = sheet
    .getRange(HEADER_ROW, 1, 1, lastCol)
    .getDisplayValues()[0];

  const sourceMap = {};
  const removedHeaders = new Set(REMOVED_OVERVIEW_HEADERS.map(cleanText_));

  headers.forEach((header, index) => {
    const key = norm_(header);

    if (key && sourceMap[key] === undefined) {
      sourceMap[key] = index;
    }
  });

  const usedIndexes = {};
  const selectedColumns = [];

  OVERVIEW_COLUMN_SPECS.forEach(spec => {
    const sourceIndex = findSourceIndexForAliases_(sourceMap, spec.aliases);

    if (sourceIndex === null) {
      if (spec.forceCreate) {
        selectedColumns.push({
          sourceIndex: null,
          header: spec.header,
        });
      }

      return;
    }

    if (usedIndexes[sourceIndex]) return;

    usedIndexes[sourceIndex] = true;

    selectedColumns.push({
      sourceIndex,
      header: spec.header,
    });
  });

  headers.forEach((header, index) => {
    const cleanHeader = cleanText_(header);

    if (!cleanHeader) return;
    if (removedHeaders.has(cleanHeader)) return;
    if (usedIndexes[index]) return;

    usedIndexes[index] = true;

    selectedColumns.push({
      sourceIndex: index,
      header: cleanHeader,
    });
  });

  if (selectedColumns.length === 0) return;

  const output = [];

  for (let row = 0; row < lastRow; row++) {
    const outRow = [];

    selectedColumns.forEach(col => {
      if (row === HEADER_ROW - 1) {
        outRow.push(col.header);
      } else if (col.sourceIndex === null) {
        outRow.push("");
      } else {
        outRow.push(formulas[row][col.sourceIndex] || values[row][col.sourceIndex]);
      }
    });

    output.push(outRow);
  }

  const neededCols = selectedColumns.length;

  sheet
    .getRange(1, 1, sheet.getMaxRows(), sheet.getMaxColumns())
    .clearContent()
    .clearDataValidations()
    .clearFormat();

  if (sheet.getMaxColumns() < neededCols) {
    sheet.insertColumnsAfter(
      sheet.getMaxColumns(),
      neededCols - sheet.getMaxColumns()
    );
  }

  if (sheet.getMaxColumns() > neededCols) {
    sheet.deleteColumns(
      neededCols + 1,
      sheet.getMaxColumns() - neededCols
    );
  }

  sheet
    .getRange(1, 1, output.length, neededCols)
    .setValues(output);

  styleOverviewHeader_(sheet);
}

function findSourceIndexForAliases_(sourceMap, aliases) {
  for (let i = 0; i < aliases.length; i++) {
    const key = norm_(aliases[i]);

    if (sourceMap[key] !== undefined) {
      return sourceMap[key];
    }
  }

  return null;
}

function resetDynamicColumnsAfterFinancialDate_(sheet) {
  deleteDynamicColumns_(sheet);

  const h = getHeaderMap_(sheet);

  let financialAnchorCol = findCol_(h, ALIASES.openregisterFinancialsDate, false);

  if (!financialAnchorCol) {
    financialAnchorCol = findCol_(h, ALIASES.northdataFinancialsDate, false);
  }

  if (!financialAnchorCol) {
    financialAnchorCol = findCol_(h, ALIASES.northdataEmployees, false);
  }

  if (!financialAnchorCol) {
    throw new Error(
      "Could not find Openregister Financials Date, Northdata Financials Date, or Northdata Employees column to place shareholder dropdowns after."
    );
  }

  insertDynamicHeaderBlock_(sheet, financialAnchorCol, SHAREHOLDER_DYNAMIC_HEADERS);

  const hAfterShareholders = getHeaderMap_(sheet);

  let uboAnchorCol = findCol_(hAfterShareholders, ALIASES.oldestShareholderAge, false);

  if (!uboAnchorCol) {
    uboAnchorCol = findCol_(hAfterShareholders, ["Shareholder Ownership %"], false);
  }

  if (!uboAnchorCol) {
    throw new Error(
      "Could not find Oldest Shareholders Age or Shareholder Ownership % column to place UBO dropdowns after."
    );
  }

  insertDynamicHeaderBlock_(sheet, uboAnchorCol, UBO_DYNAMIC_HEADERS);
}

function insertDynamicHeaderBlock_(sheet, anchorCol, headers) {
  sheet.insertColumnsAfter(anchorCol, headers.length);

  const startCol = anchorCol + 1;

  sheet
    .getRange(HEADER_ROW, startCol, 1, headers.length)
    .setValues([headers])
    .setFontWeight("bold")
    .setBackground("#1c5c5c")
    .setFontColor("#ffffff");

  sheet
    .getRange(
      HEADER_ROW + 1,
      startCol,
      Math.max(sheet.getMaxRows() - HEADER_ROW, 1),
      headers.length
    )
    .clearContent()
    .clearDataValidations()
    .clearFormat();
}

function deleteDynamicColumns_(sheet) {
  const dynamicHeaders = new Set(
    OV_DYNAMIC_HEADERS.concat(OLD_DYNAMIC_HEADERS)
  );

  const lastCol = sheet.getLastColumn();

  if (lastCol < 1) return;

  const headers = sheet
    .getRange(HEADER_ROW, 1, 1, lastCol)
    .getDisplayValues()[0];

  for (let col = lastCol; col >= 1; col--) {
    const header = cleanText_(headers[col - 1]);

    if (dynamicHeaders.has(header)) {
      sheet.deleteColumn(col);
    }
  }
}

function syncDivisionsColumn_(sheet) {
  deleteColumnsByHeader_(sheet, [DIVISION_HEADER, "Division"]);

  const h = getHeaderMap_(sheet);
  const wzCol = findCol_(h, ALIASES.wzCode, false);
  const openregisterWzCol = findCol_(h, ALIASES.openregisterWz, false);

  if (!wzCol) return;

  const insertAfterCol = openregisterWzCol || wzCol;

  sheet.insertColumnAfter(insertAfterCol);

  const divisionCol = insertAfterCol + 1;

  sheet
    .getRange(HEADER_ROW, divisionCol)
    .setValue(DIVISION_HEADER)
    .setFontWeight("bold")
    .setBackground("#1c5c5c")
    .setFontColor("#ffffff")
    .setHorizontalAlignment("center");

  const lastRow = sheet.getLastRow();

  if (lastRow <= HEADER_ROW) return;

  const rowCount = lastRow - HEADER_ROW;

  const wzValues = sheet
    .getRange(HEADER_ROW + 1, wzCol, rowCount, 1)
    .getDisplayValues();

  const divisionValues = wzValues.map(row => [
    divisionLabelFromWz_(row[0])
  ]);

  sheet
    .getRange(HEADER_ROW + 1, divisionCol, rowCount, 1)
    .setValues(divisionValues)
    .setNumberFormat("@");
}

function divisionLabelFromWz_(value) {
  const text = cleanText_(value);

  if (!text) return "";

  let match = text.match(/\b(\d{1,2})\s*\./);

  if (!match) {
    match = text.match(/\b(\d{1,2})\b/);
  }

  if (!match) return "";

  const divisionCode = parseInt(match[1], 10);

  return DIVISION_LABELS[divisionCode] || "";
}

