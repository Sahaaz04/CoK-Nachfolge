function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu("Overview Tools")
    .addItem("Setup All Dropdowns", "setupAllDropdowns")
    .addItem("Setup Overview Dropdowns", "setupOverviewDropdowns")
    .addItem("Setup Cockpit", "setupCockpit")
    .addItem("Refresh Divisions", "refreshDivisions")
    .addItem("Repair Overview Formats", "repairOverviewFormatsNow")
    .addItem("Fix Date Formats", "formatKnownDateColumns_")
    .addToUi();
}

function onEdit(e) {
  try {
    if (!e || !e.range) return;

    const sheet = e.range.getSheet();

    if (sheet.getName() !== SHEETS.cockpit) return;
    if (e.range.getA1Notation() !== COCKPIT_COMPANY_CELL) return;

    setupCockpit();
  } catch (err) {}
}

function setupAllDropdowns() {
  normalizeSheetNames_();
  setupOverviewDropdowns();
  setupCockpit();
  formatKnownDateColumns_();

  SpreadsheetApp.getActiveSpreadsheet().toast(
    "Overview reordered, Divisions added, formats repaired, and dropdowns synced.",
    "Done",
    5
  );
}

