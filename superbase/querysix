begin;

drop view if exists master_overview;

-- ============================================================
-- 1. Source-separate the remaining shared financial/employee columns
--
-- Bug: employees, balance_sheet_total_eur, net_income_eur, equity_eur,
-- cash_eur, liabilities_eur, real_estate_eur, capital_amount_eur were
-- single columns written to by BOTH northdata_import.py and
-- openregister_enrichment.py. Several were even labeled "Northdata X" in
-- the UI/exports while silently able to hold an OpenRegister value.
--
-- Fix: give each metric its own northdata_ and openregister_ column,
-- same pattern already used for revenue (northdata_revenue_eur /
-- openregister_revenue_eur). The old shared columns are frozen -
-- nothing writes to them anymore after this migration, they are kept
-- only for historical/backward-compatibility reads.
-- ============================================================

alter table companies add column if not exists northdata_employees numeric;
alter table companies add column if not exists openregister_employees numeric;

alter table companies add column if not exists northdata_balance_sheet_total_eur numeric;
alter table companies add column if not exists openregister_balance_sheet_total_eur numeric;

alter table companies add column if not exists northdata_net_income_eur numeric;
alter table companies add column if not exists openregister_net_income_eur numeric;

alter table companies add column if not exists northdata_equity_eur numeric;
alter table companies add column if not exists openregister_equity_eur numeric;

alter table companies add column if not exists northdata_cash_eur numeric;
alter table companies add column if not exists openregister_cash_eur numeric;

alter table companies add column if not exists northdata_liabilities_eur numeric;
alter table companies add column if not exists openregister_liabilities_eur numeric;

alter table companies add column if not exists northdata_real_estate_eur numeric;
alter table companies add column if not exists openregister_real_estate_eur numeric;

alter table companies add column if not exists northdata_capital_amount_eur numeric;
alter table companies add column if not exists openregister_capital_amount_eur numeric;

-- ============================================================
-- 2. Backfill from the old shared columns.
--
-- Same logic as the existing revenue backfill: NorthData-imported rows
-- backfill into the northdata_ column, everything else backfills into
-- the openregister_ column. This preserves existing data instead of
-- losing it - it does NOT tell you which source a given historical
-- value actually came from if the row's source has since changed, so
-- spot-check a few rows after running this.
-- ============================================================

do $$
declare
    metric text;
    metrics text[] := array[
        'employees',
        'balance_sheet_total_eur',
        'net_income_eur',
        'equity_eur',
        'cash_eur',
        'liabilities_eur',
        'real_estate_eur',
        'capital_amount_eur'
    ];
begin
    foreach metric in array metrics loop
        execute format(
            'update companies
             set openregister_%1$I = %1$I
             where openregister_%1$I is null
               and %1$I is not null
               and coalesce(source, '''') <> ''northdata_import''',
            metric
        );

        execute format(
            'update companies
             set northdata_%1$I = %1$I
             where northdata_%1$I is null
               and %1$I is not null
               and coalesce(source, '''') = ''northdata_import''',
            metric
        );
    end loop;
end $$;

-- ============================================================
-- 3. Indexes for the new columns most likely to be filtered/sorted on.
-- ============================================================

create index if not exists companies_northdata_employees_idx
on companies(northdata_employees);

create index if not exists companies_openregister_employees_idx
on companies(openregister_employees);

create index if not exists companies_northdata_equity_eur_idx
on companies(northdata_equity_eur);

create index if not exists companies_openregister_equity_eur_idx
on companies(openregister_equity_eur);

create index if not exists companies_northdata_net_income_eur_idx
on companies(northdata_net_income_eur);

create index if not exists companies_openregister_net_income_eur_idx
on companies(openregister_net_income_eur);

-- ============================================================
-- 4. Rebuild master_overview with the new source-specific columns.
-- ============================================================

create view master_overview as
select
    c.register_id,
    c.openregister_company_id,
    c.name as company_name,
    c.legal_form,
    c.founding_year,
    c.active,
    c.country,
    c.register_number,
    c.register_court,
    c.register_type,

    c.city,
    c.postal_code,
    c.website,
    c.email,

    c.purpose,

    c.openregister_wz_codes,
    c.northdata_wz_code,

    c.openregister_revenue_eur,
    c.northdata_revenue_eur,

    c.northdata_employees,
    c.openregister_employees,
    c.northdata_balance_sheet_total_eur,
    c.openregister_balance_sheet_total_eur,
    c.northdata_net_income_eur,
    c.openregister_net_income_eur,
    c.northdata_equity_eur,
    c.openregister_equity_eur,
    c.northdata_cash_eur,
    c.openregister_cash_eur,
    c.northdata_liabilities_eur,
    c.openregister_liabilities_eur,
    c.northdata_real_estate_eur,
    c.openregister_real_estate_eur,
    c.northdata_capital_amount_eur,
    c.openregister_capital_amount_eur,
    c.financials_date,
    c.openregister_financials_date,

    c.number_of_owners,
    c.natural_person_owner_count,
    c.legal_person_owner_count,
    c.youngest_owner_age,
    c.oldest_owner_age,
    c.has_sole_owner,
    c.has_representative_owner,
    c.is_family_owned,
    c.has_majority_owner,
    c.largest_owner_percentage,

    main_owner.shareholder_name as main_owner_name,
    main_owner.owner_type as main_owner_type,
    main_owner.percentage_share as main_owner_percentage_share,

    main_ubo.ubo_name as main_ubo_name,
    main_ubo.age as main_ubo_age,
    main_ubo.percentage_share as main_ubo_percentage_share,
    main_ubo.max_percentage_share as main_ubo_max_percentage_share,

    cm.business_segment as claude_business_segment,
    cm.business_segment_2 as claude_business_segment_2,
    cm.business_model as claude_business_model,
    cm.summary as claude_detailed_business_summary,

    fs.fit_score,
    fs.fit_label,
    fs.fit_comment

from companies c

left join lateral (
    select
        sh.shareholder_name,
        sh.owner_type,
        sh.percentage_share
    from shareholders sh
    where sh.openregister_company_id = c.openregister_company_id
      and coalesce(sh.shareholder_name, '') <> ''
    order by sh.percentage_share desc nulls last, sh.retrieved_at desc
    limit 1
) main_owner on true

left join lateral (
    select
        u.ubo_name,
        u.age,
        u.percentage_share,
        u.max_percentage_share
    from company_ubos u
    where u.openregister_company_id = c.openregister_company_id
    order by coalesce(u.percentage_share, u.max_percentage_share) desc nulls last, u.enriched_at desc
    limit 1
) main_ubo on true

left join lateral (
    select *
    from company_models cm
    where cm.openregister_company_id = c.openregister_company_id
       or cm.company_register_id = c.register_id
    order by coalesce(cm.updated_at, cm.created_at) desc nulls last
    limit 1
) cm on true

left join lateral (
    select *
    from company_fit_scores fs
    where fs.openregister_company_id = c.openregister_company_id
       or fs.company_register_id = c.register_id
    order by coalesce(fs.updated_at, fs.created_at) desc nulls last
    limit 1
) fs on true;

grant select on table master_overview to anon, authenticated;

notify pgrst, 'reload schema';

commit;
