begin;

drop view if exists master_overview;

-- ============================================================
-- 1. Claude Business Segment 2
-- Website-derived segment stays in company_models.business_segment.
-- Fallback-derived segment goes into company_models.business_segment_2.
-- ============================================================

alter table company_models
    add column if not exists business_segment_2 text;

update company_models
set
    business_segment_2 = coalesce(
        nullif(trim(business_segment_2), ''),
        nullif(
            trim(
                regexp_replace(
                    business_segment,
                    '^(appoximation|approximation) from claude[[:space:]]*-[[:space:]]*',
                    '',
                    'i'
                )
            ),
            ''
        )
    ),
    business_segment = null
where business_segment ~* '^(appoximation|approximation) from claude[[:space:]]*-';

update company_models
set business_model = null
where business_model ~* '^(appoximation|approximation) from claude[[:space:]]*-';

update company_models
set summary = null
where summary ~* '^(appoximation|approximation) from claude[[:space:]]*-';

-- ============================================================
-- 2. OpenRegister comparison columns from raw_company_details.indicators
-- These are OpenRegister-only values.
-- ============================================================

alter table companies
    add column if not exists openregister_employees numeric;

alter table companies
    add column if not exists openregister_balance_sheet_total_eur numeric;

alter table companies
    add column if not exists openregister_net_income_eur numeric;

alter table companies
    add column if not exists openregister_cash_eur numeric;

alter table companies
    add column if not exists openregister_liabilities_eur numeric;


do $$
begin
    if exists (
        select 1
        from information_schema.columns
        where table_schema = 'public'
          and table_name = 'companies'
          and column_name = 'openregister_assets_eur'
    ) then
        execute '
            update companies
            set openregister_balance_sheet_total_eur = coalesce(
                openregister_balance_sheet_total_eur,
                openregister_assets_eur
            )
            where openregister_assets_eur is not null
        ';
    end if;
end $$;

-- Backfill from the latest OpenRegister indicator row already stored in raw_company_details.
with latest_indicators as (
    select
        c.openregister_company_id,
        li.indicator
    from companies c
    join lateral (
        select elem as indicator
        from jsonb_array_elements(
            coalesce(c.raw_company_details->'indicators', '[]'::jsonb)
        ) as elem
        order by elem->>'date' desc nulls last
        limit 1
    ) li on true
    where c.openregister_company_id is not null
)
update companies c
set
    openregister_employees = coalesce(
        c.openregister_employees,
        case
            when nullif(latest_indicators.indicator->>'employees', '') is not null
            then (latest_indicators.indicator->>'employees')::numeric
            else null
        end
    ),
    openregister_balance_sheet_total_eur = coalesce(
        c.openregister_balance_sheet_total_eur,
        case
            when nullif(latest_indicators.indicator->>'balance_sheet_total', '') is not null
            then (latest_indicators.indicator->>'balance_sheet_total')::numeric / 100.0
            else null
        end
    ),
    openregister_net_income_eur = coalesce(
        c.openregister_net_income_eur,
        case
            when nullif(latest_indicators.indicator->>'net_income', '') is not null
            then (latest_indicators.indicator->>'net_income')::numeric / 100.0
            else null
        end
    ),
    openregister_cash_eur = coalesce(
        c.openregister_cash_eur,
        case
            when nullif(latest_indicators.indicator->>'cash', '') is not null
            then (latest_indicators.indicator->>'cash')::numeric / 100.0
            else null
        end
    ),
    openregister_liabilities_eur = coalesce(
        c.openregister_liabilities_eur,
        case
            when nullif(latest_indicators.indicator->>'liabilities', '') is not null
            then (latest_indicators.indicator->>'liabilities')::numeric / 100.0
            else null
        end
    )
from latest_indicators
where c.openregister_company_id = latest_indicators.openregister_company_id;

alter table companies
    drop column if exists openregister_assets_eur;

-- ============================================================
-- 3. Rebuild master_overview
-- ============================================================

create view master_overview as
select
    c.register_id,
    c.openregister_company_id,
    c.name as company_name,
    c.legal_form,
    c.founding_year,
    c.active,
    c.country,
    c.register_number,
    c.register_court,
    c.register_type,

    c.city,
    c.postal_code,
    c.website,
    c.email,

    c.purpose,

    c.openregister_wz_codes,
    c.northdata_wz_code,

    c.openregister_revenue_eur,
    c.northdata_revenue_eur,

    c.employees,
    c.openregister_employees,

    c.balance_sheet_total_eur,
    c.openregister_balance_sheet_total_eur,

    c.net_income_eur,
    c.openregister_net_income_eur,

    c.equity_eur,

    c.cash_eur,
    c.openregister_cash_eur,

    c.liabilities_eur,
    c.openregister_liabilities_eur,

    c.real_estate_eur,
    c.capital_amount_eur,
    c.financials_date,

    c.number_of_owners,
    c.natural_person_owner_count,
    c.legal_person_owner_count,
    c.youngest_owner_age,
    c.oldest_owner_age,
    c.has_sole_owner,
    c.has_representative_owner,
    c.is_family_owned,
    c.has_majority_owner,
    c.largest_owner_percentage,

    main_owner.shareholder_name as main_owner_name,
    main_owner.owner_type as main_owner_type,
    main_owner.percentage_share as main_owner_percentage_share,

    main_ubo.ubo_name as main_ubo_name,
    main_ubo.age as main_ubo_age,
    main_ubo.percentage_share as main_ubo_percentage_share,
    main_ubo.max_percentage_share as main_ubo_max_percentage_share,

    cm.business_segment as claude_business_segment,
    cm.business_segment_2 as claude_business_segment_2,
    cm.business_model as claude_business_model,
    cm.summary as claude_detailed_business_summary,

    fs.fit_score,
    fs.fit_label,
    fs.fit_comment

from companies c

left join lateral (
    select
        sh.shareholder_name,
        sh.owner_type,
        sh.percentage_share
    from shareholders sh
    where sh.openregister_company_id = c.openregister_company_id
      and coalesce(sh.shareholder_name, '') <> ''
    order by sh.percentage_share desc nulls last, sh.retrieved_at desc
    limit 1
) main_owner on true

left join lateral (
    select
        u.ubo_name,
        u.age,
        u.percentage_share,
        u.max_percentage_share
    from company_ubos u
    where u.openregister_company_id = c.openregister_company_id
    order by coalesce(u.percentage_share, u.max_percentage_share) desc nulls last, u.enriched_at desc
    limit 1
) main_ubo on true

left join lateral (
    select *
    from company_models cm
    where cm.openregister_company_id = c.openregister_company_id
       or cm.company_register_id = c.register_id
    order by coalesce(cm.updated_at, cm.created_at) desc nulls last
    limit 1
) cm on true

left join lateral (
    select *
    from company_fit_scores fs
    where fs.openregister_company_id = c.openregister_company_id
       or fs.company_register_id = c.register_id
    order by coalesce(fs.updated_at, fs.created_at) desc nulls last
    limit 1
) fs on true;

grant select on table master_overview to anon, authenticated;

notify pgrst, 'reload schema';

commit;
